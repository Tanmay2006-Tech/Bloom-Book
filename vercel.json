{
  "buildCommand": "corepack enable pnpm && pnpm install && pnpm --filter @workspace/bloombook run build",
  "devCommand": "corepack enable pnpm && pnpm install && pnpm --filter @workspace/bloombook run dev",
  "installCommand": "corepack enable pnpm && pnpm install --frozen-lockfile",
  "framework": null,
  "outputDirectory": "artifacts/bloombook/dist",
  "nodeVersion": "20.x",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "codebase-audit-and-productionize": true
    }
  },
  "env": {
    "PORT": {
      "description": "Server port for development",
      "default": "5173"
    },
    "BASE_PATH": {
      "description": "Base path for routing",
      "default": "/"
    },
    "VITE_CLOUDINARY_CLOUD_NAME": {
      "description": "Cloudinary cloud name for image hosting"
    },
    "VITE_CLOUDINARY_UPLOAD_PRESET": {
      "description": "Cloudinary upload preset"
    },
    "VITE_API_URL": {
      "description": "API server endpoint for production"
    }
  }
}
