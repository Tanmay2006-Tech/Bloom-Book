# ─────────────────────────────────────────────
#  BloomBook  ·  Environment Variables
# ─────────────────────────────────────────────
#
#  DATABASE (Neon / any PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/bloombook?sslmode=require

#  SESSION SECRET
SESSION_SECRET=your-super-secret-session-key-here

#  CLOUDINARY (photo & video uploads — browser direct upload)
#  1. Sign up free at https://cloudinary.com
#  2. Settings → Upload → Add unsigned upload preset named "bloombook_unsigned"
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=bloombook_unsigned
