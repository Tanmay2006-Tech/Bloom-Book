# Required for API data routes
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Required for persistent media uploads
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Optional runtime settings
LOG_LEVEL=info
NODE_ENV=production
CORS_ORIGIN=https://your-bloombook.vercel.app

# Optional local preview overrides
PORT=3000
BASE_PATH=/
