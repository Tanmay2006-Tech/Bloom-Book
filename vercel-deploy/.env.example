# ─────────────────────────────────────────────
#  BloomBook  ·  Environment Variables
# ─────────────────────────────────────────────
#
#  Copy this file to .env and fill in your values.
#  For Vercel: add these in Project → Settings → Environment Variables
#
#  DATABASE (Neon / any PostgreSQL)
#  Get yours free at https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/bloombook?sslmode=require

#  SESSION SECRET  (generate a random string, e.g. `openssl rand -hex 32`)
SESSION_SECRET=your-super-secret-session-key-here

#  CLOUDINARY  (photo & video uploads)
#  1. Sign up free at https://cloudinary.com
#  2. Dashboard → Settings → Upload → Add upload preset
#  3. Set preset to "Unsigned" and note the name
#  4. These VITE_ vars are exposed to the browser (that's intentional — uploads go directly from the browser to Cloudinary)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=bloombook_unsigned
